config/linkedin_storage.json
config/linkedin_profile.json
*session*.json
*storage*.json
*profile*.json

# Gmail OAuth
config/gmail_credentials.json
config/gmail_token.json
config/token.json
credentials*.json
token*.json
*gmail*.json

# API Keys & Secrets
config/api_keys.json
config/secrets.json
*secret*
*apikey*
*.key
*.pem


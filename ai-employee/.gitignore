# ═══════════════════════════════════════════════════════════════
# CRITICAL: ENVIRONMENT VARIABLES (HIGHEST PRIORITY)
# ═══════════════════════════════════════════════════════════════

# Environment variables file - CONTAINS ALL SECRETS
.env
.env.local
.env.*.local
*.env

# But allow example file
!.env.example

# ═══════════════════════════════════════════════════════════════

# AI Employee Environment Configuration
# Silver Tier Configuration

# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# =============================================================================
# VAULT CONFIGURATION
# =============================================================================
VAULT_PATH=D:/Hackathon-0/AI_Employee_Vault

# =============================================================================
# WATCHER SETTINGS
# =============================================================================
ENABLE_GMAIL_WATCHER=false
ENABLE_FILESYSTEM_WATCHER=true
ENABLE_WHATSAPP_WATCHER=false

# Gmail watcher check interval (seconds)
GMAIL_CHECK_INTERVAL=120

# WhatsApp watcher check interval (seconds)
WHATSAPP_CHECK_INTERVAL=30

# =============================================================================
# ORCHESTRATOR SETTINGS
# =============================================================================
ORCHESTRATOR_CHECK_INTERVAL=30
DASHBOARD_UPDATE_INTERVAL=300

# =============================================================================
# GMAIL CREDENTIALS (Optional - for Gmail integration)
# =============================================================================
# Place credentials.json in project root (D:\Hackathon-0\credentials.json)
# Do NOT add credentials to .env - use OAuth flow via gmail_auth.py

# =============================================================================
# LINKEDIN CREDENTIALS (Optional - for LinkedIn posting)
# =============================================================================
# Get your LinkedIn credentials by running:
#   python src/skills/linkedin_auth.py auth
# Or manually add them below (not recommended - use auth script instead):
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DRY_RUN=false
LOG_LEVEL=INFO

# =============================================================================
# REJECTED FILES AUTO-DELETE
# =============================================================================
REJECTED_AUTO_DELETE_DAYS=7
ENABLE_REJECTED_AUTO_DELETE=true

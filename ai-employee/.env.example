# AI Employee Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Vault Configuration
# ===========================================
OBSIDIAN_VAULT_PATH=D:\Hackathon-0\AI_Employee_Vault

# ===========================================
# Gmail Watcher Configuration
# ===========================================
# Set to 'true' to enable Gmail watching
ENABLE_GMAIL_WATCHER=false

# Path to Gmail OAuth credentials (credentials.json from Google Cloud)
GMAIL_CREDENTIALS_PATH=

# Path to store OAuth token (auto-generated)
# GMAIL_TOKEN_PATH=D:\Hackathon-0\AI_Employee_Vault\.cache\gmail_token.json

# Gmail API settings
GMAIL_CHECK_INTERVAL=120
GMAIL_QUERY=is:unread is:important

# ===========================================
# Filesystem Watcher Configuration
# ===========================================
# Set to 'true' to enable filesystem watching
ENABLE_FILESYSTEM_WATCHER=true

# Folder to monitor for file drops
WATCH_FOLDER=D:\Hackathon-0\AI_Employee_Vault\Inbox

# Filesystem check interval (seconds)
FILESYSTEM_CHECK_INTERVAL=30

# ===========================================
# Orchestrator Configuration
# ===========================================
# How often to check for new items (seconds)
ORCHESTRATOR_CHECK_INTERVAL=30

# How often to update dashboard (seconds)
DASHBOARD_UPDATE_INTERVAL=300

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===========================================
# Development Settings
# ===========================================
# Set to 'true' to prevent actual file creation/modification
DRY_RUN=false

# Development mode - disables external actions
DEV_MODE=true

# ===========================================
# Qwen Code Configuration
# ===========================================
# Path to Qwen Code CLI (if not in PATH)
# QWEN_CODE_PATH=

# Qwen Code model to use
# QWEN_MODEL=

# ===========================================
# MCP Server Configuration
# ===========================================
# MCP configuration file path
# MCP_CONFIG_PATH=

# ===========================================
# Security Settings
# ===========================================
# Maximum actions per hour (rate limiting)
MAX_ACTIONS_PER_HOUR=100

# Payment approval threshold (USD)
PAYMENT_APPROVAL_THRESHOLD=500

# ===========================================
# Notifications (Optional)
# ===========================================
# Email for system notifications
# NOTIFICATION_EMAIL=

# Webhook URL for alerts
# ALERT_WEBHOOK_URL=

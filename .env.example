# AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ═══════════════════════════════════════════════════════════
# VAULT CONFIGURATION
# ═══════════════════════════════════════════════════════════
# Path to your Obsidian vault
VAULT_PATH=D:/Hackathon-0/AI_Employee_Vault

# ═══════════════════════════════════════════════════════════
# WATCHER SETTINGS
# ═══════════════════════════════════════════════════════════
# Enable/disable watchers
ENABLE_GMAIL_WATCHER=false
ENABLE_FILESYSTEM_WATCHER=true

# ═══════════════════════════════════════════════════════════
# ORCHESTRATOR SETTINGS
# ═══════════════════════════════════════════════════════════
# Seconds between orchestrator checks
ORCHESTRATOR_CHECK_INTERVAL=30

# Seconds between dashboard updates
DASHBOARD_UPDATE_INTERVAL=300

# ═══════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════
# Set to true for testing (no actual actions taken)
DRY_RUN=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════
# GMAIL API CREDENTIALS (Optional - for Gmail integration)
# ═══════════════════════════════════════════════════════════
# Get these from Google Cloud Console
# See: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# ═══════════════════════════════════════════════════════════
# LINKEDIN CREDENTIALS (Optional - for LinkedIn posting)
# ═══════════════════════════════════════════════════════════
# Your LinkedIn email and password for browser automation
# Note: Use with caution and review LinkedIn Terms of Service
LINKEDIN_EMAIL=your_linkedin_email_here
LINKEDIN_PASSWORD=your_linkedin_password_here
